{
  "name": "comfyui-lora-tag-hash-metadata",
  "version": "1.0.2",
  "description": "ComfyUI node that converts <lora:name:weight> tags into Civitai-friendly Name:HASH:Weight metadata strings.",
  "type": "module",
  "scripts": {
    "dev": "tsc && vite build --watch",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "comfyui",
    "custom node",
    "extension",
    "civitai",
    "lora",
    "metadata",
    "image saver"
  ],
  "author": "PBandDev",
  "license": "MIT",
  "packageManager": "pnpm@10.17.1",
  "dependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  },
  "devDependencies": {
    "@comfyorg/comfyui-frontend-types": "^1.32.1",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.0.16",
    "vitest": "^4.0.16"
  }
}
